        "message": "=<!DOCTYPE html> <html lang=\"es\"> <head><meta charset=\"UTF-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"></head> <body style=\"margin:0;padding:24px;background:#f4f4f4;font-family:Arial,sans-serif\">  <div style=\"max-width:560px;margin:0 auto;background:#ffffff;border-radius:12px;overflow:hidden;border:1px solid #e0e0e0\">    <!-- Header -->   <div style=\"background:#A32D2D;padding:20px 28px\">     <p style=\"color:#FCEBEB;font-size:18px;font-weight:bold;margin:0\">⚠ Alerta de KPI fuera de umbral</p>     <p style=\"color:#F7C1C1;font-size:13px;margin:6px 0 0\">Sistema de monitoreo de catálogo — n8n</p>   </div>    <div style=\"padding:24px 28px\">      <!-- Mensaje de advertencia -->     <div style=\"background:#FCEBEB;border-left:3px solid #E24B4A;padding:12px 16px;margin-bottom:20px\">       <p style=\"color:#791F1F;font-size:13px;margin:0;line-height:1.5\">         El KPI <strong>{{ $json.nombre_kpi }}</strong> esta por debajo el umbral configurado y requiere atención inmediata.       </p>     </div>      <!-- Tabla de datos -->     <table style=\"width:100%;border-collapse:collapse;font-size:14px;margin-bottom:20px\">       <tr style=\"background:#f9f9f9\">         <td style=\"padding:10px 14px;color:#888;font-size:13px;width:40%\">KPI</td>         <td style=\"padding:10px 14px;font-weight:bold;color:#222\">{{ $json.nombre_kpi }}</td>       </tr>       <tr>         <td style=\"padding:10px 14px;color:#888;font-size:13px;border-top:1px solid #f0f0f0\">Valor actual</td>         <td style=\"padding:10px 14px;font-weight:bold;color:#A32D2D;border-top:1px solid #f0f0f0\">{{ $json.valor_kpi }}</td>       </tr>       <tr style=\"background:#f9f9f9\">         <td style=\"padding:10px 14px;color:#888;font-size:13px;border-top:1px solid #f0f0f0\">Umbral configurado</td>         <td style=\"padding:10px 14px;font-weight:bold;color:#222;border-top:1px solid #f0f0f0\">{{ $json.umbral }}</td>       </tr>       <tr>         <td style=\"padding:10px 14px;color:#888;font-size:13px;border-top:1px solid #f0f0f0\">Estado</td>         <td style=\"padding:10px 14px;border-top:1px solid #f0f0f0\">           <span style=\"background:#FCEBEB;color:#791F1F;font-size:12px;padding:3px 10px;border-radius:4px;font-weight:bold\">ALERTA</span>         </td>       </tr>       <tr style=\"background:#f9f9f9\">         <td style=\"padding:10px 14px;color:#888;font-size:13px;border-top:1px solid #f0f0f0\">Fecha y hora</td>         <td style=\"padding:10px 14px;font-weight:bold;color:#222;border-top:1px solid #f0f0f0\">{{ $json.fecha_hora }}</td>       </tr>     </table>      <!-- Mensaje -->     <div style=\"background:#f9f9f9;border-radius:8px;padding:14px 16px;margin-bottom:24px\">       <p style=\"font-size:13px;color:#888;margin:0 0 4px;font-weight:bold\">Mensaje</p>       <p style=\"font-size:14px;color:#222;margin:0;line-height:1.6\">         El catálogo presenta una calidad por debajo del mínimo aceptable. Se recomienda revisar los productos con campos incompletos (brand, images, dimensions) y tomar acción correctiva.       </p>     </div>      <!-- Footer -->     <div style=\"border-top:1px solid #f0f0f0;padding-top:16px\">       <p style=\"font-size:12px;color:#aaa;margin:0;line-height:1.6\">         Este mensaje fue generado automáticamente por el sistema de monitoreo KPI.<br>         No responder a este correo.       </p>     </div>    </div> </div>  </body> </html> {{ $json.nombre_kpi }}",
