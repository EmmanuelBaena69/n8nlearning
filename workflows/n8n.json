    {
      "parameters": {
        "jsCode": "// Calidad del Catálogo (Data Quality)\nconst productos = $input.first().json.products;\nconst total = productos.length;\n\nconst con_marca = productos.filter(p => p.brand && p.brand.trim() !== '').length;\nconst pct_marca = Math.round((con_marca / total)*100*10) / 10;\n\nconst con_img = productos.filter(p => p.images && p.images.length > 0).length;\nconst pct_img = Math.round((con_img / total)*100*10) / 10;\n\nconst con_dimensiones = productos.filter(p => p.dimensions && typeof p.dimensions.width === 'number' && typeof p.dimensions.height === 'number' && typeof p.dimensions.depth === 'number').length;\nconst pct_dimension = Math.round((con_dimensiones / total)*100*10) / 10;\n\nconst calidad_catalogo = Math.round(((pct_marca + pct_img + pct_dimension) / 3 ) * 10) / 10;\n\nconst umbral = 90;\nconst estado = calidad_catalogo >= umbral ? 'OK' : 'ALERTA';\n\nreturn [{\n  json: {\n    nombre_kpi: 'Calidad catalogo KPI-01',\n    valor_kpi: calidad_catalogo,\n    estado,\n    umbral\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
